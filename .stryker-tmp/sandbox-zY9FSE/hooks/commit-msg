#!/bin/sh
# Conventional commit check with scope validation
MSG=$(head -1 "$1")

if ! echo "$MSG" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .+'; then
  echo "  ✗ Commit message must follow Conventional Commits"
  echo "    e.g.: feat(ms): add new feature"
  exit 1
fi

# Validate scope is a known package (if scope is present)
SCOPE=$(echo "$MSG" | sed -n 's/^[a-z]*(\([^)]*\)).*/\1/p')
if [ -n "$SCOPE" ]; then
  # Allow comma-separated scopes
  for S in $(echo "$SCOPE" | tr ',' ' '); do
    if [ ! -d "packages/$S" ]; then
      echo "  ✗ Unknown scope '$S'. Must be a package in packages/"
      echo "    Available: $(ls packages/ | tr '\n' ', ' | sed 's/,$//')"
      exit 1
    fi
  done
fi
