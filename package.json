{
  "name": "flupke",
  "private": true,
  "description": "Foundational Libraries Under Packages Known & Established — hardened drop-in replacements for neglected npm leaf packages",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath hooks",
    "build": "tsc --build packages/*/tsconfig.json",
    "test": "node --test packages/*/test/*.test.js",
    "bench": "node packages/*/bench/*.bench.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "override": "node scripts/generate-overrides.js",
    "catalog": "node scripts/generate-catalog.js"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/javascript-mutator": "4.0.0",
    "cookie": "1.1.1",
    "depd": "2.0.0",
    "dotenv": "17.4.2",
    "escape-html": "1.0.3",
    "fast-json-stable-stringify": "2.1.0",
    "function-bind": "1.1.2",
    "inherits": "2.0.4",
    "isarray": "2.0.5",
    "ms": "2.1.3",
    "safe-buffer": "5.2.1",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rkristelijn/flupke"
  }
}
