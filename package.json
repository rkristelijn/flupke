{
  "name": "flupke",
  "private": true,
  "description": "Foundational Libraries Under Packages Known & Established — hardened drop-in replacements for neglected npm leaf packages",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build packages/*/tsconfig.json",
    "test": "node --test packages/*/test/*.test.js",
    "bench": "node packages/*/bench/*.bench.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "override": "node scripts/generate-overrides.js"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
